{
  "name": "devlog",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @devlog/design-system dev",
    "build": "bun run --workspaces --if-present build",
    "lint": "bun run --workspaces --if-present lint",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "ui:add": "bunx --bun shadcn@latest add -c packages/ui"
  }
}
