{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/devlog-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|Inter))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ColumnPicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:tree|path|onSelect|onCommit|style|key|ref|className|style|children)$/]",
        "message": "<ColumnPicker> doesn't accept that prop. Declared props: tree, path, onSelect, onCommit, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommandList'] > JSXAttribute > JSXIdentifier[name!=/^(?:paths|query|activeIndex|onSelect|onHover|header|style|key|ref|className|style|children)$/]",
        "message": "<CommandList> doesn't accept that prop. Declared props: paths, query, activeIndex, onSelect, onHover, header, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Composer'] > JSXAttribute > JSXIdentifier[name!=/^(?:context|value|defaultValue|placeholder|onChange|onSubmit|onBadgeClick|badgeActive|popover|autoFocus|style|key|ref|className|style|children)$/]",
        "message": "<Composer> doesn't accept that prop. Declared props: context, value, defaultValue, placeholder, onChange, onSubmit, onBadgeClick, badgeActive, popover, autoFocus, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContextBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:path|size|active|interactive|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ContextBadge> doesn't accept that prop. Declared props: path, size, active, interactive, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContextBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<ContextBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DateDivider'] > JSXAttribute > JSXIdentifier[name!=/^(?:date|sticky|style|key|ref|className|style|children)$/]",
        "message": "<DateDivider> doesn't accept that prop. Declared props: date, sticky, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|icon|children|onClose|confirmLabel|cancelLabel|onConfirm|confirmVariant|actions|width|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, title, icon, children, onClose, confirmLabel, cancelLabel, onConfirm, confirmVariant, actions, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute[name.name='confirmVariant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Dialog> confirmVariant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|stroke|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, stroke, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|iconSize|active|title|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, size, iconSize, active, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kbd'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<Kbd> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogEntry'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|time|context|status|onCopy|style|key|ref|className|style|children)$/]",
        "message": "<LogEntry> doesn't accept that prop. Declared props: title, body, time, context, status, onCopy, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogEntry'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:done|progress|failed|note)$/]",
        "message": "<LogEntry> status must be one of 'done' | 'progress' | 'failed' | 'note'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|blink|color|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, size, blink, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:full|mark|bracket)$/]",
        "message": "<Logo> variant must be one of 'full' | 'mark' | 'bracket'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, tone, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|success|warning|danger|context)$/]",
        "message": "<Tag> tone must be one of 'neutral' | 'accent' | 'success' | 'warning' | 'danger' | 'context'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|children|placement|style|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: label, children, placement, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='placement'] > Literal[value!=/^(?:top|bottom|left|right)$/]",
        "message": "<Tooltip> placement must be one of 'top' | 'bottom' | 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TreeNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|path|children|defaultOpen|key|ref|className|style|children)$/]",
        "message": "<TreeNode> doesn't accept that prop. Declared props: label, path, children, defaultOpen."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
